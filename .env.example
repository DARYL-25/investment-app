# SQLite for local dev; use a PostgreSQL URL in production
# (and change prisma/schema.prisma datasource provider to "postgresql")
DATABASE_URL="file:./dev.db"

# Secret for signing session JWTs — generate with: openssl rand -hex 32
AUTH_SECRET=""

# Optional: Financial Modeling Prep API key for enhanced fundamentals
FMP_API_KEY=""

# Optional: Anthropic API key for AI-powered ETF discovery & portfolio assistant
ANTHROPIC_API_KEY=""
